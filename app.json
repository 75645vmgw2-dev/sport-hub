{
  "expo": {
    "name": "KAZMO",
    "slug": "kazmo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#080814"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kazmo.login",
      "buildNumber": "3",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Kazmo utilise la camera pour votre photo de profil.",
        "NSPhotoLibraryUsageDescription": "Kazmo accede a vos photos pour votre photo de profil.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.kazmo.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#080814",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-speech-recognition",
      "expo-apple-authentication",
      "expo-notifications",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.579139707826-7na99fj0talskda7l0sfquuqkvd020qs"
        }
      ],
      "expo-localization",
      "expo-splash-screen",
      "./withModularHeaders"
    ],
    "extra": {
      "eas": {
        "projectId": "3cf98fe2-b872-475b-bb43-e6034ec85261"
      }
    },
    "owner": "jackomel69",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3cf98fe2-b872-475b-bb43-e6034ec85261"
    },
    "scheme": "kazmo"
  }
}